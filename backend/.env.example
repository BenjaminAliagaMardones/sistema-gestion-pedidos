# Variables de entorno para el backend

# Base de datos PostgreSQL (proporcionada por Render)
DATABASE_URL=postgresql://user:password@localhost:5432/shoper_db

# JWT - Cambiar en producción a una cadena aleatoria larga y segura
JWT_SECRET=CAMBIA_ESTO_EN_PRODUCCION_POR_UNA_CLAVE_SEGURA
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Nombre de la app
APP_NAME=Sistema Shoper

# Usuario administrador (se crea automáticamente al iniciar)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CAMBIA_ESTO_EN_PRODUCCION

# URL del frontend (para CORS)
FRONTEND_URL=https://tu-frontend.onrender.com

# Debug (false en producción)
DEBUG=false
